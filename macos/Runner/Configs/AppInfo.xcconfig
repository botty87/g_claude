// Application-level settings for the Runner target.

// The application's binary name. Kept as snake_case for path-safe scripting.
PRODUCT_NAME = g_claude

// The application's bundle identifier (reverse-DNS Timeware).
PRODUCT_BUNDLE_IDENTIFIER = it.timeware.gclaude

// The copyright displayed in application information
PRODUCT_COPYRIGHT = Copyright © 2026 Timeware Srl. All rights reserved.
